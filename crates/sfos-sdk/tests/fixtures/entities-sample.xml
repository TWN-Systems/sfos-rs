<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
  <Zone><Name>LAN</Name><Type>LAN</Type></Zone>
  <Zone><Name>WAN</Name><Type>WAN</Type></Zone>
  <Zone><Name>DMZ</Name><Type>DMZ</Type></Zone>
  <IPHost>
    <Name>WebServer</Name><IPFamily>IPv4</IPFamily>
    <HostType>IP</HostType><IPAddress>10.0.10.5</IPAddress>
  </IPHost>
  <IPHost>
    <Name>LAN-Net</Name><IPFamily>IPv4</IPFamily>
    <HostType>Network</HostType><IPAddress>10.0.0.0</IPAddress><Subnet>255.255.0.0</Subnet>
  </IPHost>
  <Services>
    <Name>HTTPS</Name><Type>TCPorUDP</Type>
    <ServiceDetails>
      <ServiceDetail><SourcePort>1:65535</SourcePort><DestinationPort>443</DestinationPort><Protocol>TCP</Protocol></ServiceDetail>
    </ServiceDetails>
  </Services>
  <FirewallRule>
    <Name>LAN-to-WAN</Name><Status>Enable</Status><IPFamily>IPv4</IPFamily>
    <Position>Top</Position><PolicyType>Network</PolicyType>
    <NetworkPolicy>
      <Action>Accept</Action><LogTraffic>Enable</LogTraffic>
      <SourceZones><Zone>LAN</Zone></SourceZones>
      <DestinationZones><Zone>WAN</Zone></DestinationZones>
      <SourceNetworks><Network>LAN-Net</Network></SourceNetworks>
      <Services><Service>HTTPS</Service></Services>
      <IntrusionPrevention>generalpolicy</IntrusionPrevention>
    </NetworkPolicy>
  </FirewallRule>
  <FirewallRule>
    <Name>WAN-inbound-web</Name><Status>Enable</Status><PolicyType>Network</PolicyType>
    <NetworkPolicy>
      <Action>Accept</Action>
      <SourceZones><Zone>WAN</Zone></SourceZones>
      <DestinationZones><Zone>DMZ</Zone></DestinationZones>
      <DestinationNetworks><Network>WebServer</Network></DestinationNetworks>
      <Services><Service>HTTPS</Service></Services>
    </NetworkPolicy>
  </FirewallRule>
  <FirewallRule>
    <Name>old-guest-block</Name><Status>Disable</Status><PolicyType>Network</PolicyType>
    <NetworkPolicy>
      <Action>Drop</Action>
      <SourceZones><Zone>GUEST</Zone></SourceZones>
      <DestinationZones><Zone>WAN</Zone></DestinationZones>
    </NetworkPolicy>
  </FirewallRule>
</Configuration>
